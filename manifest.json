{
  "manifest_version": 3,
  "name": "TabAmber",
  "version": "1.0.0",
  "description": "Your tabs, preserved in amber. Suspends inactive tabs by time with no count limits. Chrome and Firefox.",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "alarms",
    "scripting",
    "idle",
    "notifications"
  ],
  "host_permissions": [
    "*://*/*"
  ],
  "background": {
    "service_worker": "sw.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*/*"
      ],
      "match_about_blank": true,
      "js": [
        "inject/watch.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TabAmber"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tab-suspender@local",
      "strict_min_version": "109.0"
    }
  }
}